{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "profile",
  "main": "worker.js",
  "compatibility_date": "2025-09-27",
  "account_id": "${{ secrets.CLOUDFLARE_ACCOUNT_ID }}",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "send_email": [
    {
      "name": "SEND_EMAIL",
      "destination_address": "gsalast@mail.com"
    }
  ]
}
