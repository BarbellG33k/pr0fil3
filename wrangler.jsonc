{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "profile",
  "main": "worker.js",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "include": ["*.html", "*.json", "*.css", "*.js", "*.png", "*.jpg", "*.svg"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "send_email": [
    {
      "name": "SEND_EMAIL",
      "destination_address": "gsalast@mail.com"
    }
  ]
}
